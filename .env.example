# --- Telegram ---
# Get from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Leave empty for open access. Recommended: set to your own ID during development.
TELEGRAM_ALLOWED_USER_IDS=

# --- Xiaomi MiMo ---
# Get from https://platform.xiaomimimo.com/
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_REASONING_MODEL=mimo-reasoning
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=zh_female_xiaoyu

# --- Speech-to-Text ---
# Provider: "openai" (Whisper API) or "local" (placeholder for future faster-whisper)
STT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1

# --- Behavior ---
LOG_LEVEL=INFO
# Max characters of conversation history kept per user (rough budget)
MEMORY_BUDGET_CHARS=8000
# System persona, used as the system prompt for the reasoning model
PERSONA="Kamu adalah VoiceMate ID, asisten suara berbahasa Indonesia. Jawaban singkat, jelas, dan ramah, maksimal 3-4 kalimat agar enak didengar. Hindari simbol markdown atau emoji."
